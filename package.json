    "express": "^4.18.2",
    "mongoose": "^8.0.3",
    "pino": "^8.17.1",
    "qrcode-terminal": "^0.12.0",
    "axios": "^1.6.5",
    "cheerio": "^1.0.0-rc.12",
    "jimp": "^0.22.10",
    "moment-timezone": "^0.5.45",
    "file-type": "^19.0.0",
    "dotenv": "^16.3.1",
    "fs-extra": "^11.2.0",
    "wa-sticker-formatter": "^4.0.0",
    "yt-search": "^2.10.4",
